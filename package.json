{
  "name": "easy-peasy",
  "version": "7.0.0-beta.0",
  "description": "Vegetarian friendly state for React",
  "license": "MIT",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "source": "src/index.js",
  "types": "./index.d.ts",
  "sideEffects": true,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js"
    },
    "./server": {
      "types": "./server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs.js"
    },
    "./map-set-support": "./map-set-support.js"
  },
  "files": [
    "dist",
    "src",
    "index.d.ts",
    "server.d.ts",
    "map-set-support.js",
    "map-set-support.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ctrlplusb/easy-peasy.git"
  },
  "homepage": "https://easy-peasy.dev",
  "contributors": [
    {
      "name": "Sean Matheson",
      "email": "sean@ctrlplusb.com",
      "url": "https://twitter.com/controlplusb"
    },
    {
      "name": "Jørn André Myrland",
      "url": "https://twitter.com/myrlandnu"
    },
    {
      "name": "Peter Weinberg",
      "url": "https://github.com/no-stack-dub-sack"
    }
  ],
  "keywords": [
    "react",
    "redux",
    "state",
    "typescript"
  ],
  "scripts": {
    "build": "rollup -c",
    "clean": "rimraf ./dist && rimraf ./coverage",
    "lint": "eslint --fix src tests",
    "dtslint": "tsc --noEmit -p tests/typescript/tsconfig.json",
    "prepublish": "yarn run build",
    "prepublishOnly": "yarn",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:deploy": "yarn run test:coverage",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18"
  },
  "resolutions": {
    "@types/react": "^19.0.8"
  },
  "peerDependencies": {
    "@types/react": "^19.0",
    "@types/react-dom": "^19.0",
    "react": "^19.0",
    "react-dom": "^19.0",
    "react-native": ">=0.59"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "dependencies": {
    "fast-deep-equal": "^3.1.3",
    "immer": "^11.1.4",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0",
    "ts-toolbelt": "^9.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.9",
    "@babel/plugin-transform-react-jsx": "^7.22.5",
    "@babel/preset-env": "^7.22.9",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-babel": "^6",
    "@rollup/plugin-node-resolve": "^16",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/react-redux": "^7.1.34",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9",
    "jsdom": "^29.0.2",
    "prettier": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "rimraf": "^5.0.1",
    "rollup": "^4",
    "shallowequal": "^1.1.0",
    "typescript": "5.7.3",
    "vitest": "^3"
  },
  "prettier": {
    "proseWrap": "always",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "all"
  }
}
